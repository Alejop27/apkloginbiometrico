<!--
  AndroidManifest.xml — Permisos adicionales requeridos para Seg4.

  INSTRUCCIONES:
  Copia estos <uses-permission> DENTRO del tag <manifest> de tu
  android/app/src/main/AndroidManifest.xml, ANTES del tag <application>.

  Además, en el tag <activity> agrega:
    android:windowSoftInputMode="adjustResize"
-->

<!-- Permisos de red (peticiones HTTP al backend) -->
<uses-permission android:name="android.permission.INTERNET" />

<!-- Biometría: huella dactilar -->
<uses-permission android:name="android.permission.USE_BIOMETRIC" />

<!-- Legado (dispositivos Android < 9) -->
<uses-permission android:name="android.permission.USE_FINGERPRINT" />


<!--
  IMPORTANTE — Configuración de seguridad de red (Android 9+):
  Si tu backend corre en HTTP (no HTTPS) en desarrollo, añade en
  android/app/src/main/res/xml/network_security_config.xml:

  <?xml version="1.0" encoding="utf-8"?>
  <network-security-config>
    <domain-config cleartextTrafficPermitted="true">
      <domain includeSubdomains="true">10.0.2.2</domain>
      <domain includeSubdomains="true">192.168.x.x</domain>
    </domain-config>
  </network-security-config>

  Y en AndroidManifest.xml > <application> añade:
    android:networkSecurityConfig="@xml/network_security_config"
  -->
